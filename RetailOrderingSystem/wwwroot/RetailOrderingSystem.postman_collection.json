{
  "info": {
    "name": "Retail Ordering System API",
    "description": "Complete Postman collection for the Retail Ordering System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:7001", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\",\n  \"phoneNumber\": \"9876543210\",\n  \"address\": \"123 Main Street\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@retail.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        },
        {
          "name": "Login (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/categories" }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/categories",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Desserts\",\n  \"description\": \"Sweet desserts and cakes\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products" }
        },
        {
          "name": "Search Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products?search=pizza" }
        },
        {
          "name": "Filter by Category",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products?categoryId=1" }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"BBQ Chicken Pizza\",\n  \"description\": \"Smoky BBQ chicken with onions\",\n  \"price\": 299,\n  \"stockQuantity\": 30,\n  \"minimumStockLevel\": 5,\n  \"categoryId\": 1\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/cart",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/cart/items",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/cart",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"couponCode\": null,\n  \"loyaltyPointsToRedeem\": 0,\n  \"deliveryAddress\": \"123 Main Street\"\n}"
            }
          }
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/my-orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "All Orders (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/all?page=1&pageSize=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/orders/1/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Accepted\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Coupons",
      "item": [
        {
          "name": "Create Coupon (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/coupons",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SAVE20\",\n  \"discountPercentage\": 20,\n  \"fixedDiscountAmount\": 0,\n  \"minimumOrderAmount\": 200,\n  \"expiryDate\": \"2027-12-31T00:00:00Z\",\n  \"usageLimit\": 100\n}"
            }
          }
        },
        {
          "name": "Apply Coupon (Customer)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/coupons/apply",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"couponCode\": \"SAVE20\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reports (Admin)",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reports/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Daily Sales",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reports/sales/daily?date=2026-06-01",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Top Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reports/top-products?count=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Inventory (Admin)",
      "item": [
        {
          "name": "Update Stock",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/inventory/1/stock",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newQuantity\": 100,\n  \"transactionType\": \"StockAdded\",\n  \"notes\": \"Restocked from supplier\"\n}"
            }
          }
        },
        {
          "name": "Low Stock Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/inventory/low-stock",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Delivery Partner",
      "item": [
        {
          "name": "Get Assigned Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/delivery/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Accept Order",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/delivery/orders/1/accept",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Mark Delivered",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/delivery/orders/1/deliver",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    }
  ]
}
